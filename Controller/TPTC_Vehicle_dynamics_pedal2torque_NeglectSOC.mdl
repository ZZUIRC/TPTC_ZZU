      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [T_cmd_limited,state] = f( ...
    T_req,risk,warn,limit_ratio, ...
    Tmax_mot,Tlim_up_rate,Tlim_down_rate,...
    Tlim_warn_rate,Ts)
%#codegen

% ============================================================
% MCU级三级自适应限扭器
%
% state：
%   0 Normal  ：100%
%   1 Warning ：通常82%，轻度限扭
%   2 Risk    ：50%～70%，快速限扭
%
% limit_ratio由Slip Detector给出：
%   Normal  = 1.00
%   Warning = 0.82
%   Risk    = 自适应0.50～0.70
% ============================================================

persistent initialized
persistent T_cmd_z
persistent limited_z

if isempty(initialized)

    T_cmd_z = 0.0;
    limited_z = false;

    initialized = true;
end


%% 采样周期

if Ts &gt; 0.0
    Ts_eff = Ts;
else
    Ts_eff = 1.0e-3;
end


%% 参数保护

Tmax_eff = max(abs(Tmax_mot),1.0);

up_rate = max(abs(Tlim_up_rate),1.0);

risk_down_rate = ...
    max(abs(Tlim_down_rate),1.0);

warn_down_rate = ...
    max(abs(Tlim_warn_rate),1.0);


%% 请求扭矩

T_req_abs = min(abs(T_req),Tmax_eff);

req_sign = 1.0;

if T_req &lt; 0.0
    req_sign = -1.0;
end


%% 状态

if risk

    state = 2.0;

elseif warn

    state = 1.0;

else

    state = 0.0;
end


%% 无扭矩请求

if T_req_abs &lt; 0.5

    T_cmd_z = 0.0;
    limited_z = false;

    T_cmd_limited = 0.0;
    return;
end


