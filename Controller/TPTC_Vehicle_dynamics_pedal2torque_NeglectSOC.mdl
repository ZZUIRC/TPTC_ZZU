if T_cmd_z*T_req &lt; 0.0

    T_cmd_z = 0.0;
    limited_z = false;
end


%% 限扭比例保护

ratio_eff = limit_ratio;

if ratio_eff &lt; 0.45

    ratio_eff = 0.45;

elseif ratio_eff &gt; 1.0

    ratio_eff = 1.0;
end


%% 目标扭矩

T_target_abs = ...
    ratio_eff*T_req_abs;

T_current_abs = ...
    abs(T_cmd_z);


if state ~= 0.0 || ratio_eff &lt; 0.999

    limited_z = true;
