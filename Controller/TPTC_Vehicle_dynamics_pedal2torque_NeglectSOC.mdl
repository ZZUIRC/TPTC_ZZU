<?xml version="1.0" encoding="utf-8"?>
<chart id="79">
  <P Name="name">Powertrain/03_MCU_TPTC_Controller/Torque_Limiter/Torque_Limiter_Front/Fast_Down_Slow_Up_Limiter</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">79</P>
  <P Name="ssIdHighWaterMark">20</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">4</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">f</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">79</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [T_cmd_limited,state] = f( ...
    T_req,risk,warn,limit_ratio, ...
    Tmax_mot,Tlim_up_rate,Tlim_down_rate,...
    Tlim_warn_rate,Ts)
%#codegen

% ============================================================
% MCU级三级自适应限扭器
%
% state：
%   0 Normal  ：100%
%   1 Warning ：通常82%，轻度限扭
%   2 Risk    ：50%～70%，快速限扭
%
% limit_ratio由Slip Detector给出：
%   Normal  = 1.00
%   Warning = 0.82
%   Risk    = 自适应0.50～0.70
% ============================================================

persistent initialized
persistent T_cmd_z
persistent limited_z

if isempty(initialized)

    T_cmd_z = 0.0;
    limited_z = false;

    initialized = true;
end


%% 采样周期

if Ts &gt; 0.0
    Ts_eff = Ts;
else
    Ts_eff = 1.0e-3;
end


%% 参数保护

Tmax_eff = max(abs(Tmax_mot),1.0);

up_rate = max(abs(Tlim_up_rate),1.0);

risk_down_rate = ...
    max(abs(Tlim_down_rate),1.0);

warn_down_rate = ...
    max(abs(Tlim_warn_rate),1.0);


%% 请求扭矩

T_req_abs = min(abs(T_req),Tmax_eff);

req_sign = 1.0;

if T_req &lt; 0.0
    req_sign = -1.0;
end


%% 状态

if risk

    state = 2.0;

elseif warn

    state = 1.0;

else

    state = 0.0;
end


%% 无扭矩请求

if T_req_abs &lt; 0.5

    T_cmd_z = 0.0;
    limited_z = false;

    T_cmd_limited = 0.0;
    return;
end


%% 扭矩方向变化

if T_cmd_z*T_req &lt; 0.0

    T_cmd_z = 0.0;
    limited_z = false;
end


%% 限扭比例保护

ratio_eff = limit_ratio;

if ratio_eff &lt; 0.45

    ratio_eff = 0.45;

elseif ratio_eff &gt; 1.0

    ratio_eff = 1.0;
end


%% 目标扭矩

T_target_abs = ...
    ratio_eff*T_req_abs;

T_current_abs = ...
    abs(T_cmd_z);


if state ~= 0.0 || ratio_eff &lt; 0.999

    limited_z = true;
end


%% 扭矩下降

if T_target_abs &lt; T_current_abs

    if state == 2.0

        % Risk快速下降
        step_down = ...
            risk_down_rate*Ts_eff;

        T_current_abs = ...
            max(T_target_abs,...
            T_current_abs-step_down);

    elseif state == 1.0

        % Warning中速下降
        step_down = ...
            warn_down_rate*Ts_eff;

        T_current_abs = ...
            max(T_target_abs,...
            T_current_abs-step_down);

    else

        % 上层主动降低扭矩请求时直接跟随
        T_current_abs = T_target_abs;
    end


%% 扭矩增加和恢复

elseif T_target_abs &gt; T_current_abs

    if limited_z

        % 发生过限扭后慢速恢复
        step_up = ...
            up_rate*Ts_eff;

        T_current_abs = ...
            min(T_target_abs,...
            T_current_abs+step_up);

    else

        % 正常请求直接跟随
        T_current_abs = T_target_abs;
    end
end


%% 恢复完成

if state == 0.0 &amp;&amp; ...
        abs(T_current_abs-T_req_abs) &lt; 0.5

    limited_z = false;
end


%% 输出

T_cmd_z = ...
    req_sign*T_current_abs;

T_cmd_limited = T_cmd_z;

end</P>
      </eml>
    </state>
