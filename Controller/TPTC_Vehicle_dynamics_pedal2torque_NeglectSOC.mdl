<?xml version="1.0" encoding="utf-8"?>
<chart id="124">
  <P Name="name">03_MCU_ASR_Controller1/Slip_Detector_Front/MATLAB Function</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">124</P>
  <P Name="ssIdHighWaterMark">28</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">7</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">f</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">124</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [risk,warn,state,load_ratio,follow_bad,axis_diverge,startup_guard] = f( ...
    Te,alpha,Tload,omega, ...
    Te_opp,alpha_opp,Tload_opp,omega_opp, ...
    T_active,alpha_thr,Ts)
%#codegen

% ============================================================
% MCU级 TCPC/ASR Slip Detector
%
% 核心判据：
% 1. Tload_est / Te 偏低
% 2. Te 增加时，Tload_est 不跟随增加
% 3. alpha 异常升高作为确认条件
%
% axis_diverge 只做诊断输出，不单独触发 warn/risk
%
% state:
%   0 Normal
%   1 Warning
%   2 Risk
% ============================================================

persistent risk_z warn_z
persistent Te_z Tload_z omega_z omega_opp_z
persistent active_cnt risk_enter_cnt warn_enter_cnt risk_exit_cnt warn_exit_cnt

if isempty(risk_z)
    risk_z = false;
    warn_z = false;

    Te_z = 0.0;
    Tload_z = 0.0;
    omega_z = 0.0;
    omega_opp_z = 0.0;

    active_cnt = 0.0;
    risk_enter_cnt = 0.0;
    warn_enter_cnt = 0.0;
    risk_exit_cnt = 0.0;
    warn_exit_cnt = 0.0;
end

% =========================
% 采样时间保护
% =========================
if Ts &lt;= 0.0
    Ts_eff = 1e-3;
else
    Ts_eff = Ts;
end

% =========================
% 可标定参数
% =========================

% 负载比例阈值
k_load_risk = 0.72;
k_load_warn = 0.86;

% 跟随性阈值
k_follow_risk = 0.20;
k_follow_warn = 0.40;

% alpha 阈值
alpha_warn_gain = 0.65;
alpha_risk_gain = 1.00;

% 起步保护
startup_guard_time = 0.30;
startup_guard_steps = ceil(startup_guard_time / Ts_eff);

% 起步阶段只允许较强 risk
alpha_start_risk_gain = 1.40;
k_load_start_risk = 0.55;

% 进入确认时间
% risk 不要太慢，否则压不住滑移；warn 稍微确认
risk_enter_confirm_time = 0.005;  % 5 ms
warn_enter_confirm_time = 0.020;  % 20 ms

risk_enter_steps = ceil(risk_enter_confirm_time / Ts_eff);
warn_enter_steps = ceil(warn_enter_confirm_time / Ts_eff);

% 退出确认时间
risk_exit_confirm_time = 0.080;   % 80 ms，避免频繁退出
warn_exit_confirm_time = 0.050;   % 50 ms

risk_exit_steps = ceil(risk_exit_confirm_time / Ts_eff);
warn_exit_steps = ceil(warn_exit_confirm_time / Ts_eff);

% dTe 太小时不判断跟随性
dTe_min = max(0.02*T_active, 0.5);

% 前后轴分化诊断阈值
alpha_diff_thr = 0.80*alpha_thr;
omega_diff_thr = 5.0;
omega_diff_rate_thr = 50.0;

% =========================
% 有效驱动区
% =========================
active = (Te &gt; T_active);

if active
    active_cnt = active_cnt + 1.0;
else
    active_cnt = 0.0;
end

startup_guard = active &amp;&amp; (active_cnt &lt;= startup_guard_steps);

% =========================
% 负载比例
% =========================
Te_eff = max(Te, 1.0);
load_ratio_raw = Tload / Te_eff;

if load_ratio_raw &lt; 0.0
    load_ratio = 0.0;
elseif load_ratio_raw &gt; 2.0
    load_ratio = 2.0;
else
    load_ratio = load_ratio_raw;
end

load_gap_risk = (load_ratio &lt; k_load_risk);
load_gap_warn = (load_ratio &lt; k_load_warn);

% =========================
% Tload 是否随 Te 增加
% =========================
dTe = Te - Te_z;
dTload = Tload - Tload_z;

torque_rising = (dTe &gt; dTe_min);

follow_bad_risk = torque_rising &amp;&amp; (dTload &lt; k_follow_risk*dTe);
follow_bad_warn = torque_rising &amp;&amp; (dTload &lt; k_follow_warn*dTe);

follow_bad = follow_bad_risk;

% =========================
% alpha 异常
% =========================
alpha_risk = (alpha &gt; alpha_risk_gain*alpha_thr);
alpha_warn = (alpha &gt; alpha_warn_gain*alpha_thr);

% =========================
% 前后轴分化，仅诊断
% =========================
omega_diff = omega - omega_opp;
omega_diff_z = omega_z - omega_opp_z;
d_omega_diff = (omega_diff - omega_diff_z) / Ts_eff;

alpha_diverge = (alpha &gt; alpha_opp + alpha_diff_thr) &amp;&amp; alpha_warn;

omega_diverge = (~startup_guard) &amp;&amp; ...
                (omega_diff &gt; omega_diff_thr) &amp;&amp; ...
                (d_omega_diff &gt; omega_diff_rate_thr);

axis_diverge = alpha_diverge || omega_diverge;

% =========================
% 原始进入判据
% =========================
if startup_guard

    % 起步保护阶段：
    % 不允许 warn，只允许强 risk
    warn_enter_raw = false;

    risk_enter_raw = active &amp;&amp; ...
                     (alpha &gt; alpha_start_risk_gain*alpha_thr) &amp;&amp; ...
                     ((load_ratio &lt; k_load_start_risk) || follow_bad_risk);

else

    % 正常阶段：
    % axis_diverge 不直接触发
    risk_enter_raw = active &amp;&amp; ...
                     alpha_risk &amp;&amp; ...
                     (load_gap_risk || follow_bad_risk);

    warn_enter_raw = active &amp;&amp; ...
                     alpha_warn &amp;&amp; ...
                     (load_gap_warn || follow_bad_warn);
end

% =========================
% 进入确认
% =========================
if risk_enter_raw
    risk_enter_cnt = risk_enter_cnt + 1.0;
else
    risk_enter_cnt = 0.0;
end

if warn_enter_raw
    warn_enter_cnt = warn_enter_cnt + 1.0;
else
    warn_enter_cnt = 0.0;
end

risk_enter = (risk_enter_cnt &gt;= risk_enter_steps);
warn_enter = (warn_enter_cnt &gt;= warn_enter_steps);

% =========================
% 退出判据
% =========================
risk_exit_raw = (~active) || ...
                ( ...
                  (alpha &lt; 0.45*alpha_thr) &amp;&amp; ...
                  (load_ratio &gt; 0.88) &amp;&amp; ...
                  (~follow_bad_warn) ...
                );

warn_exit_raw = (~active) || ...
                ( ...
                  (alpha &lt; 0.35*alpha_thr) &amp;&amp; ...
                  (load_ratio &gt; 0.96) &amp;&amp; ...
                  (~follow_bad_warn) ...
                );

if risk_exit_raw
    risk_exit_cnt = risk_exit_cnt + 1.0;
else
    risk_exit_cnt = 0.0;
end

if warn_exit_raw
    warn_exit_cnt = warn_exit_cnt + 1.0;
else
    warn_exit_cnt = 0.0;
end

risk_exit = (risk_exit_cnt &gt;= risk_exit_steps);
warn_exit = (warn_exit_cnt &gt;= warn_exit_steps);

% =========================
% risk 滞回
% =========================
if risk_z
    if risk_exit
        risk_z = false;
        risk_exit_cnt = 0.0;
    end
else
    if risk_enter
        risk_z = true;
        risk_enter_cnt = 0.0;
    end
end

% =========================
% warn 滞回
% =========================
if risk_z
    warn_z = false;
    warn_exit_cnt = 0.0;
else
    if warn_z
        if warn_exit
            warn_z = false;
            warn_exit_cnt = 0.0;
        end
    else
        if warn_enter
            warn_z = true;
            warn_enter_cnt = 0.0;
        end
    end
end

% =========================
% 输出
% =========================
risk = risk_z;
warn = warn_z;

if risk_z
    state = 2.0;
elseif warn_z
    state = 1.0;
else
    state = 0.0;
end

% =========================
% 更新历史量
% =========================
Te_z = Te;
Tload_z = Tload;
omega_z = omega;
omega_opp_z = omega_opp;

end</P>
      </eml>
    </state>
    <data SSID="4" name="Te">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
