__MWOPC_PART_BEGIN__ /simulink/stateflow/chart_186.xml
<?xml version="1.0" encoding="utf-8"?>
<chart id="186">
  <P Name="name">03_MCU_ASR_Controller1/Torque_Limiter_Rear/Fast_Down_Slow_Up_Limiter</P>
  <P Name="windowPosition">[422 539.941 189 413]</P>
  <P Name="viewLimits">[0 156.75 0 153.75]</P>
  <P Name="screen">[1 1 3600 1200 1.180555555555556]</P>
  <P Name="viewObj">186</P>
  <P Name="ssIdHighWaterMark">27</P>
  <P Name="decomposition">CLUSTER_CHART</P>
  <P Name="type">EML_CHART</P>
  <P Name="chartFileNumber">10</P>
  <P Name="disableImplicitCasting">1</P>
  <eml>
    <P Name="name">f</P>
  </eml>
  <Children>
    <state SSID="1">
      <P Name="labelString">eML_blk_kernel()</P>
      <P Name="position">[18 64.5 118 66]</P>
      <P Name="fontSize">12</P>
      <P Name="superState">SUBCHART</P>
      <P Name="subviewer">186</P>
      <P Name="type">FUNC_STATE</P>
      <P Name="decomposition">CLUSTER_STATE</P>
      <eml>
        <P Name="isEML">1</P>
        <P Name="script">function [Tlim,state] = f(T_vcu,risk,warn,Tload,Tmax_mot,Tlim_up_rate,Tlim_down_rate,Tlim_warn_rate,Ts_asr)
%#codegen

% ============================================================
% MCU级 TCPC/ASR 限扭器 v5
%
% state:
%   0 Normal
%   1 Warning
%   2 SpinDown
%   3 Hold
%   4 Recovery
%
% 核心策略：
%   1. risk 时快速降低 Tcap 和 Tlim
%   2. 打滑后进入 Hold，不立即恢复
%   3. Recovery 只恢复到 Tcap
%   4. Tcap 只在稳定后小斜率上探
%   5. 避免恢复-打滑-恢复的大幅搏动
% ============================================================

persistent Tlim_z state_z hold_cnt recover_cnt drive_cnt
persistent Tload_lpf_z first_run
persistent Tcap_z stable_cnt

if isempty(Tlim_z)
    Tlim_z = 0.0;
    state_z = 0.0;
    hold_cnt = 0.0;
    recover_cnt = 0.0;
    drive_cnt = 0.0;

    Tload_lpf_z = 0.0;
    first_run = true;

    Tcap_z = 0.0;
    stable_cnt = 0.0;
end

% =========================
% 状态定义
% =========================
S_NORMAL   = 0.0;
S_WARNING  = 1.0;
S_SPINDOWN = 2.0;
S_HOLD     = 3.0;
S_RECOVERY = 4.0;

% =========================
% 采样时间保护
% =========================
if Ts_asr &lt;= 0.0
    Ts = 1e-3;
else
    Ts = Ts_asr;
end

% =========================
% 可标定参数
% =========================

% 状态时间
spin_hold_time = 0.25;        % 低扭矩保持 250 ms
recovery_min_time = 0.35;     % Recovery 至少 350 ms

spin_hold_steps = ceil(spin_hold_time / Ts);
recovery_min_steps = ceil(recovery_min_time / Ts);

% Tload 低通
tau_Tload = 0.060;            % 60 ms

% SpinDown 目标
T_decel_margin = 18.0;        % T_spin_target = Tload_ref - margin
T_spin_min = 0.0;
T_spin_keep_min = 0.0;

% 动态 Tcap
Tcap_margin_recover = 8.0;    % risk 后 Tcap 收敛到 Tload_ref + 8
Tcap_drop_rate = 5000.0;      % risk 时 Tcap 下降速率
Tcap_min = 0.0;

% Tcap 试探增长
Tcap_probe_rate_slow = 6.0;   % 低附着/不确定
Tcap_probe_rate_mid  = 25.0;  % 中等
Tcap_probe_rate_fast = 80.0;  % 高附着确认

stable_time_for_probe = 0.30; % 稳定 300 ms 后才允许 Tcap 上探
stable_steps_for_probe = ceil(stable_time_for_probe / Ts);

% warn 处理
warn_freeze_time = 0.10;      % Recovery 中 warn 冻结 100 ms
T_warn_min = 15.0;

% 上升速率
Tlim_normal_up_rate = 1.2*Tlim_up_rate;
Tlim_recovery_up_rate = 0.45*Tlim_up_rate;

% 起步软限制
startup_time = 0.60;
startup_steps = ceil(startup_time / Ts);
T_cmd_active_thr = max(1.0,0.02*Tmax_mot);
startup_ramp_rate = 0.40*Tmax_mot / max(startup_time,Ts);

% 最终输出斜率保护
Tlim_final_down_rate = max(Tlim_down_rate,1500.0);
Tlim_final_up_rate   = max(Tlim_recovery_up_rate,1.0);

% =========================
% 目标扭矩
% =========================
target_raw = min(max(T_vcu,0.0),Tmax_mot);

if first_run
    Tlim_z = 0.0;
    Tload_lpf_z = max(Tload,0.0);
    Tcap_z = target_raw;
    first_run = false;
end

% =========================
% 驱动计时
% =========================
cmd_active = target_raw &gt; T_cmd_active_thr;

if cmd_active
    drive_cnt = drive_cnt + 1.0;
else
    drive_cnt = 0.0;
end

startup_phase = cmd_active &amp;&amp; (drive_cnt &lt;= startup_steps);

% =========================
% Tload 低通
% =========================
Tload_eff = Tload;

if Tload_eff &lt; 0.0
    Tload_eff = 0.0;
end

a_lpf = Ts / (tau_Tload + Ts);
Tload_lpf_z = Tload_lpf_z + a_lpf*(Tload_eff - Tload_lpf_z);

Tload_ref = Tload_lpf_z;

% =========================
% Tcap 更新
% =========================

% 当前负载跟随程度
Tlim_eff = max(Tlim_z,1.0);
load_ratio_cap = Tload_ref / Tlim_eff;

load_follow_good = (load_ratio_cap &gt; 0.90);
load_follow_mid  = (load_ratio_cap &gt; 0.75);

if risk

    % risk 时快速压低 Tcap
    Tcap_target_down = Tload_ref + Tcap_margin_recover;

    if Tcap_target_down &lt; Tcap_min
        Tcap_target_down = Tcap_min;
    end

    if Tcap_z &gt; Tcap_target_down
        Tcap_z = Tcap_z - Tcap_drop_rate*Ts;

        if Tcap_z &lt; Tcap_target_down
            Tcap_z = Tcap_target_down;
        end
    else
        Tcap_z = Tcap_target_down;
    end

    stable_cnt = 0.0;

else

    if ~warn
        stable_cnt = stable_cnt + 1.0;
    else
        stable_cnt = 0.0;
    end

    if stable_cnt &gt;= stable_steps_for_probe

        if load_follow_good
            Tcap_probe_rate_now = Tcap_probe_rate_fast;
        elseif load_follow_mid
            Tcap_probe_rate_now = Tcap_probe_rate_mid;
        else
            Tcap_probe_rate_now = Tcap_probe_rate_slow;
        end

        if Tcap_z &lt; target_raw
            Tcap_z = Tcap_z + Tcap_probe_rate_now*Ts;

            if Tcap_z &gt; target_raw
                Tcap_z = target_raw;
            end
        else
            Tcap_z = target_raw;
        end
    end
end

% Tcap 限幅
if Tcap_z &gt; Tmax_mot
    Tcap_z = Tmax_mot;
elseif Tcap_z &lt; 0.0
    Tcap_z = 0.0;
end

% 实际目标被 Tcap 限制
target = min(target_raw,Tcap_z);

% VCU 请求降低时，立即跟随
if Tlim_z &gt; target_raw
    Tlim_z = target_raw;
end

% =========================
% SpinDown 目标
% =========================
T_spin_target = Tload_ref - T_decel_margin;

if T_spin_target &lt; T_spin_min
    T_spin_target = T_spin_min;
end

if T_spin_target &gt; target_raw
    T_spin_target = target_raw;
end

T_spin_keep_eff = min(T_spin_keep_min,target_raw);
T_warn_min_eff = min(T_warn_min,target_raw);

% =========================
% 状态转移
% =========================
switch state_z

    case S_NORMAL

        hold_cnt = 0.0;
        recover_cnt = 0.0;

        if risk
            state_z = S_SPINDOWN;
            hold_cnt = spin_hold_steps;

        elseif warn
            state_z = S_WARNING;

        else
            state_z = S_NORMAL;
        end

    case S_WARNING

        if risk
            state_z = S_SPINDOWN;
            hold_cnt = spin_hold_steps;

        elseif warn
            state_z = S_WARNING;

        else
            if Tlim_z &lt; target
                state_z = S_RECOVERY;
                recover_cnt = recovery_min_steps;
            else
                state_z = S_NORMAL;
            end
        end

    case S_SPINDOWN

        if risk
            state_z = S_SPINDOWN;
            hold_cnt = spin_hold_steps;
        else
            state_z = S_HOLD;
            hold_cnt = spin_hold_steps;
        end

    case S_HOLD

        if risk
            state_z = S_SPINDOWN;
            hold_cnt = spin_hold_steps;
        else
            if hold_cnt &gt; 0.0
                hold_cnt = hold_cnt - 1.0;
                state_z = S_HOLD;
            else
                state_z = S_RECOVERY;
                recover_cnt = recovery_min_steps;
            end
        end

    case S_RECOVERY

        if risk
            state_z = S_SPINDOWN;
            hold_cnt = spin_hold_steps;

        elseif warn
            % warn 时只冻结，不强降
            state_z = S_HOLD;
            hold_cnt = ceil(warn_freeze_time / Ts);

        else
            if recover_cnt &gt; 0.0
                recover_cnt = recover_cnt - 1.0;
                state_z = S_RECOVERY;
            else
                if Tlim_z &lt; target
                    state_z = S_RECOVERY;
                else
                    state_z = S_NORMAL;
                    recover_cnt = 0.0;
                end
            end
        end

    otherwise

        state_z = S_NORMAL;
        hold_cnt = 0.0;
        recover_cnt = 0.0;
end

% =========================
% 计算 Tlim_ref
% =========================
Tlim_ref = Tlim_z;

if state_z == S_SPINDOWN

    % 快速降到 Tload_ref - margin
    if Tlim_z &gt; T_spin_target
        Tlim_ref = Tlim_z - Tlim_down_rate*Ts;

        if Tlim_ref &lt; T_spin_target
            Tlim_ref = T_spin_target;
        end
    else
        Tlim_ref = Tlim_z;
    end

    if Tlim_ref &lt; T_spin_keep_eff
        Tlim_ref = T_spin_keep_eff;
    end

elseif state_z == S_HOLD

    % Hold：保持低扭矩；如果仍偏高，继续缓慢向 T_spin_target 靠近
    if Tlim_z &gt; T_spin_target
        Tlim_ref = Tlim_z - 0.20*Tlim_down_rate*Ts;

        if Tlim_ref &lt; T_spin_target
            Tlim_ref = T_spin_target;
        end
    else
        Tlim_ref = Tlim_z;
    end

    if Tlim_ref &lt; T_spin_keep_eff
        Tlim_ref = T_spin_keep_eff;
    end

elseif state_z == S_WARNING

    % Warning：只轻微降扭
    Tlim_ref = Tlim_z - Tlim_warn_rate*Ts;

    if Tlim_ref &lt; T_warn_min_eff
        Tlim_ref = T_warn_min_eff;
    end

    if Tlim_ref &gt; target
        Tlim_ref = target;
    end

elseif state_z == S_RECOVERY

    % Recovery：只恢复到 target = min(T_vcu, Tcap)
    if target &gt; Tlim_z
        Tlim_ref = Tlim_z + Tlim_recovery_up_rate*Ts;

        if Tlim_ref &gt; target
            Tlim_ref = target;
        end
    else
        Tlim_ref = target;
    end

else

    % Normal：也只跟随 target = min(T_vcu, Tcap)
    if target &gt; Tlim_z
        Tlim_ref = Tlim_z + Tlim_normal_up_rate*Ts;

        if Tlim_ref &gt; target
            Tlim_ref = target;
        end
    else
        Tlim_ref = target;
    end
end

% =========================
% 起步软限制
% =========================
if startup_phase &amp;&amp; ...
   (state_z == S_NORMAL || state_z == S_WARNING || state_z == S_RECOVERY)

    startup_Tlim = startup_ramp_rate * drive_cnt * Ts;

    if Tlim_ref &gt; startup_Tlim
        Tlim_ref = startup_Tlim;
    end
end

% =========================
% 最终输出斜率保护
% =========================
dT = Tlim_ref - Tlim_z;

if dT &gt; Tlim_final_up_rate*Ts
    dT = Tlim_final_up_rate*Ts;
elseif dT &lt; -Tlim_final_down_rate*Ts
    dT = -Tlim_final_down_rate*Ts;
end

Tlim_z = Tlim_z + dT;

% =========================
% 最终限幅
% =========================
if Tlim_z &gt; Tmax_mot
    Tlim_z = Tmax_mot;
elseif Tlim_z &lt; 0.0
    Tlim_z = 0.0;
end

if Tlim_z &gt; target_raw
    Tlim_z = target_raw;
end

Tlim = Tlim_z;
state = state_z;

end</P>
      </eml>
    </state>
    <data SSID="4" name="T_vcu">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="5" name="Tlim">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="6" name="risk">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="7" name="warn">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="20" name="Tload">
      <P Name="scope">INPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="8" name="state">
      <P Name="scope">OUTPUT_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_NO</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="14" name="Tmax_mot">
      <P Name="scope">PARAMETER_DATA</P>
      <P Name="paramIndexForInitFromWorkspace">3</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="15" name="Tlim_up_rate">
      <P Name="scope">PARAMETER_DATA</P>
      <P Name="paramIndexForInitFromWorkspace">1</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="17" name="Tlim_down_rate">
      <P Name="scope">PARAMETER_DATA</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="18" name="Tlim_warn_rate">
      <P Name="scope">PARAMETER_DATA</P>
      <P Name="paramIndexForInitFromWorkspace">2</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
    </data>
    <data SSID="19" name="Ts_asr">
      <P Name="scope">PARAMETER_DATA</P>
      <P Name="paramIndexForInitFromWorkspace">4</P>
      <props>
        <array>
          <P Name="size">-1</P>
        </array>
        <type>
          <P Name="method">SF_INHERITED_TYPE</P>
          <P Name="primitive">SF_DOUBLE_TYPE</P>
          <P Name="isSigned">1</P>
          <P Name="wordLength">16</P>
        </type>
        <P Name="complexity">SF_COMPLEX_INHERITED</P>
        <P Name="frame">SF_FRAME_INHERITED</P>
        <unit>
          <P Name="name">inherit</P>
        </unit>
      </props>
      <P Name="dataType">Inherit: Same as Simulink</P>
